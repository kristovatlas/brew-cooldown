#!/usr/bin/env bash
# brew-cooldown: refuse Homebrew install/upgrade/reinstall of formulae whose
# current version landed in homebrew-core (or homebrew-cask) less than N days
# ago. Defense-in-depth against the "compromised formula caught within days"
# supply-chain class.
#
# See docs/spec.md for behavior, docs/threat-model.md for what's protected.

# Strict mode in production. Skipped when sourced in lib mode for tests, since
# set -e would otherwise infect the bats test harness.
if [[ "${BREW_COOLDOWN_LIB_ONLY:-0}" != "1" ]]; then
    set -euo pipefail
    IFS=$'\n\t'
fi

readonly BC_VERSION="0.1.0"
readonly BC_DEFAULT_DAYS=7
readonly BC_DEFAULT_MAX_REWIND_COMMITS=30
readonly BC_GITHUB_API="https://api.github.com"
readonly BC_RAW_GITHUB="https://raw.githubusercontent.com"
readonly BC_CORE_REPO="Homebrew/homebrew-core"
readonly BC_CASK_REPO="Homebrew/homebrew-cask"
# Formula/cask names: lowercase letter or digit start; then letters, digits,
# . _ + @ - allowed. Max 100 chars. Stricter than Homebrew's actual rules
# (which permit some uppercase) — we are deliberately conservative.
readonly BC_NAME_RE='^[a-z0-9][a-zA-Z0-9._+@-]{0,99}$'

# Mutable state populated by helpers. Globals because bash 3.2 can't return
# multiple values from a function cleanly.
_age_days=""
_eligible_at_iso=""
_latest_commit_iso=""
_error_reason=""
_cfg_days=""
_cfg_token=""
_cfg_fail_open=""
_cfg_disable=""
_cfg_debug=""
_cfg_no_rewind=""
_cfg_max_rewind_commits=""

# Rewind path state (per-invocation).
_rewound_sha=""
_rewound_iso=""
_rewound_age_days=""
_rewind_tap_dir=""
_rewind_tap_ns=""

###############################################################################
# logging / errors
###############################################################################

log_info()  { printf 'brew-cooldown: %s\n' "$*" >&2; }
log_warn()  { printf 'brew-cooldown: WARN: %s\n' "$*" >&2; }
log_error() { printf 'brew-cooldown: ERROR: %s\n' "$*" >&2; }
debug() {
    if [[ "${BC_DEBUG:-0}" == "1" ]]; then
        printf 'brew-cooldown: DEBUG: %s\n' "$*" >&2
    fi
}

# Redact GitHub-token-shaped substrings from any message before logging.
mask_token() {
    local s="${1:-}"
    s="$(printf '%s' "$s" | sed -E 's/(ghp|gho|ghu|ghs|ghr|github_pat)_[A-Za-z0-9_]+/[REDACTED]/g')"
    s="$(printf '%s' "$s" | sed -E 's/([Aa]uthorization: [Bb]earer )[A-Za-z0-9._~+/=-]+/\1[REDACTED]/g')"
    printf '%s' "$s"
}

die() {
    local code="$1"; shift
    log_error "$*"
    exit "$code"
}

###############################################################################
# url encoding (only for the chars we know GitHub treats specially)
###############################################################################

urlencode() {
    local s="$1"
    s="${s//%/%25}"
    s="${s//@/%40}"
    s="${s//+/%2B}"
    s="${s// /%20}"
    printf '%s' "$s"
}

###############################################################################
# validation
###############################################################################

# Check if a formula/cask name is well-formed and not a third-party tap.
# Returns 0 if valid, 1 otherwise. Never invokes curl or brew.
validate_formula_name() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then return 1; fi
    if [[ ${#name} -gt 100 ]]; then return 1; fi
    if [[ "$name" == */* ]]; then return 1; fi
    if [[ ! "$name" =~ $BC_NAME_RE ]]; then return 1; fi
    return 0
}

###############################################################################
# config file
###############################################################################

# Parse $XDG_CONFIG_HOME/brew-cooldown/config (or $HOME/.config/...).
# Strict KEY=value lines. Allowlist-validated. Never sourced.
load_config() {
    local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/brew-cooldown/config"
    if [[ ! -r "$cfg" ]]; then return 0; fi

    local line key value lineno=0
    while IFS= read -r line || [[ -n "$line" ]]; do
        lineno=$((lineno + 1))
        line="${line#"${line%%[![:space:]]*}"}"
        if [[ -z "$line" ]]; then continue; fi
        if [[ "$line" == \#* ]]; then continue; fi
        if [[ ! "$line" =~ ^([A-Z_][A-Z0-9_]*)=(.*)$ ]]; then
            debug "config $cfg:$lineno ignored (not KEY=value)"
            continue
        fi
        key="${BASH_REMATCH[1]}"
        value="${BASH_REMATCH[2]}"
        if [[ "$value" =~ ^\"(.*)\"$ ]] || [[ "$value" =~ ^\'(.*)\'$ ]]; then
            value="${BASH_REMATCH[1]}"
        fi
        case "$key" in
            BREW_COOLDOWN_DAYS)
                if [[ "$value" =~ ^[0-9]{1,4}$ ]]; then _cfg_days="$value"
                else debug "config $cfg:$lineno BREW_COOLDOWN_DAYS rejected"
                fi
                ;;
            BREW_COOLDOWN_GITHUB_TOKEN)
                if [[ "$value" =~ ^[A-Za-z0-9_]{1,200}$ ]]; then _cfg_token="$value"
                else debug "config $cfg:$lineno BREW_COOLDOWN_GITHUB_TOKEN rejected"
                fi
                ;;
            BREW_COOLDOWN_FAIL_OPEN)
                if [[ "$value" =~ ^[01]$ ]]; then _cfg_fail_open="$value"
                else debug "config $cfg:$lineno BREW_COOLDOWN_FAIL_OPEN rejected"
                fi
                ;;
            BREW_COOLDOWN_DISABLE)
                if [[ "$value" =~ ^[01]$ ]]; then _cfg_disable="$value"
                else debug "config $cfg:$lineno BREW_COOLDOWN_DISABLE rejected"
                fi
                ;;
            BREW_COOLDOWN_DEBUG)
                if [[ "$value" =~ ^[01]$ ]]; then _cfg_debug="$value"
                else debug "config $cfg:$lineno BREW_COOLDOWN_DEBUG rejected"
                fi
                ;;
            BREW_COOLDOWN_NO_REWIND)
                if [[ "$value" =~ ^[01]$ ]]; then _cfg_no_rewind="$value"
                else debug "config $cfg:$lineno BREW_COOLDOWN_NO_REWIND rejected"
                fi
                ;;
            BREW_COOLDOWN_MAX_REWIND_COMMITS)
                if [[ "$value" =~ ^[0-9]{1,3}$ ]] && (( value >= 1 && value <= 100 )); then
                    _cfg_max_rewind_commits="$value"
                else
                    debug "config $cfg:$lineno BREW_COOLDOWN_MAX_REWIND_COMMITS rejected (must be 1-100)"
                fi
                ;;
            *)
                debug "config $cfg:$lineno unrecognized key $key"
                ;;
        esac
    done < "$cfg"
}

###############################################################################
# repo path resolution
###############################################################################

# Map a name + kind (formula|cask) to its path inside Homebrew/homebrew-core
# or Homebrew/homebrew-cask.
#
# Subdir conventions (verified by listing the contents endpoint on the
# default branch — see U-11d):
#   formulae starting with `lib`   → Formula/lib/<name>.rb
#   all other formulae             → Formula/<first>/<name>.rb
#   casks starting with `font-`    → Casks/font/<name>.rb
#   all other casks                → Casks/<first>/<name>.rb
repo_path_for() {
    local name="$1" kind="${2:-formula}"
    local first="${name:0:1}"
    case "$kind" in
        formula)
            if [[ "$name" == lib* ]]; then
                printf 'Formula/lib/%s.rb' "$name"
            else
                printf 'Formula/%s/%s.rb' "$first" "$name"
            fi
            ;;
        cask)
            if [[ "$name" == font-* ]]; then
                printf 'Casks/font/%s.rb' "$name"
            else
                printf 'Casks/%s/%s.rb' "$first" "$name"
            fi
            ;;
        *) return 1 ;;
    esac
}

###############################################################################
# github fetch
###############################################################################

# GET the latest commit on the given file path in the given repo. Sets
# _latest_commit_iso on success, _error_reason on failure. Returns 0/2.
fetch_latest_commit_date() {
    local repo="$1" path="$2"
    local enc_path
    enc_path="$(urlencode "$path")"
    local url="${BC_GITHUB_API}/repos/${repo}/commits?path=${enc_path}&per_page=1"

    local headers=(-H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28")
    if [[ -n "${BC_TOKEN:-}" ]]; then
        headers+=(-H "Authorization: Bearer ${BC_TOKEN}")
    fi

    debug "GET $url"

    local response http_code body
    if ! response=$(curl -sS --max-time 15 -w $'\n%{http_code}' "${headers[@]}" "$url" 2>&1); then
        _error_reason="curl error: $(mask_token "$response")"
        return 2
    fi
    http_code="${response##*$'\n'}"
    body="${response%$'\n'*}"
    if [[ "$body" == "$response" ]]; then body=""; fi

    case "$http_code" in
        200) ;;
        403)
            if printf '%s' "$body" | jq -e '(.message // "") | test("rate limit"; "i")' >/dev/null 2>&1; then
                _error_reason="GitHub API rate limit exceeded (HTTP 403). Set BREW_COOLDOWN_GITHUB_TOKEN to raise to 5000/hr."
            else
                _error_reason="GitHub HTTP 403 (forbidden) for $path"
            fi
            return 2
            ;;
        404) _error_reason="formula/cask not found at $repo/$path (HTTP 404)"; return 2 ;;
        000) _error_reason="curl failed before HTTP exchange (network error)"; return 2 ;;
        *)   _error_reason="GitHub returned HTTP $http_code for $path"; return 2 ;;
    esac

    local date_str
    if ! date_str=$(printf '%s' "$body" | jq -r '.[0].commit.committer.date // empty' 2>/dev/null); then
        _error_reason="malformed JSON from GitHub"
        return 2
    fi
    if [[ -z "$date_str" ]]; then
        _error_reason="empty commit list at $path (formula may not exist)"
        return 2
    fi
    _latest_commit_iso="$date_str"
    return 0
}

###############################################################################
# time helpers (cross-platform: GNU date on Linux, BSD date on macOS)
###############################################################################

iso_to_epoch() {
    local iso="$1" epoch
    if epoch=$(date -u -d "$iso" +%s 2>/dev/null); then
        printf '%s' "$epoch"; return 0
    fi
    if epoch=$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$iso" +%s 2>/dev/null); then
        printf '%s' "$epoch"; return 0
    fi
    return 1
}

epoch_now() { date -u +%s; }

age_days() {
    local iso="$1" then_e now_e
    then_e=$(iso_to_epoch "$iso") || return 1
    now_e=$(epoch_now)
    printf '%d' $(( (now_e - then_e) / 86400 ))
}

epoch_to_iso() {
    local e="$1"
    if date -u -d "@$e" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null; then return 0; fi
    if date -u -r "$e" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null; then return 0; fi
    return 1
}

###############################################################################
# decision
###############################################################################

# check_cooldown <name> <kind=formula|cask>
# Returns 0 = eligible, 1 = held, 2 = error (sets _error_reason).
# Always populates _age_days, _latest_commit_iso, _eligible_at_iso when known.
check_cooldown() {
    local name="$1" kind="${2:-formula}"
    _age_days=""; _eligible_at_iso=""; _latest_commit_iso=""; _error_reason=""

    local repo
    case "$kind" in
        formula) repo="$BC_CORE_REPO" ;;
        cask)    repo="$BC_CASK_REPO" ;;
        *) _error_reason="unknown kind: $kind"; return 2 ;;
    esac

    local path
    if ! path=$(repo_path_for "$name" "$kind"); then
        _error_reason="cannot determine repo path for $name ($kind)"
        return 2
    fi

    if ! fetch_latest_commit_date "$repo" "$path"; then
        return 2
    fi

    local age then_epoch eligible_epoch
    if ! age=$(age_days "$_latest_commit_iso"); then
        _error_reason="cannot parse commit date: $_latest_commit_iso"
        return 2
    fi
    _age_days="$age"
    if ! then_epoch=$(iso_to_epoch "$_latest_commit_iso"); then
        _error_reason="cannot parse commit date: $_latest_commit_iso"
        return 2
    fi
    eligible_epoch=$(( then_epoch + BC_DAYS * 86400 ))
    if ! _eligible_at_iso=$(epoch_to_iso "$eligible_epoch"); then
        _eligible_at_iso="(unable to format)"
    fi

    if (( age >= BC_DAYS )); then
        return 0
    else
        return 1
    fi
}

###############################################################################
# N-stable rewind (ADR-0008)
###############################################################################

# Pure function. Reads lines of "<sha> <iso_date>" sorted newest-first from
# stdin. Prints "<sha> <iso> <age_days>" for the most recent N-stable commit
# (per ADR-0008 definition: HEAD with age ≥ N, or non-HEAD with next-later gap
# ≥ N). Returns 1 if no candidate is N-stable within the input.
find_n_stable_commit() {
    local days="$1"
    local threshold=$(( days * 86400 ))
    local now_e; now_e=$(epoch_now)

    local shas=() isos=() epochs=()
    local sha iso epoch line
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        sha="${line%% *}"
        iso="${line#* }"
        [[ -z "$sha" || -z "$iso" || "$iso" == "$sha" ]] && continue
        epoch=$(iso_to_epoch "$iso") || continue
        shas+=("$sha"); isos+=("$iso"); epochs+=("$epoch")
    done

    local k=${#shas[@]}
    (( k == 0 )) && return 1

    local i gap age
    for (( i = 0; i < k; i++ )); do
        if (( i == 0 )); then
            gap=$(( now_e - epochs[0] ))
        else
            gap=$(( epochs[i-1] - epochs[i] ))
        fi
        if (( gap >= threshold )); then
            age=$(( (now_e - epochs[i]) / 86400 ))
            printf '%s %s %s\n' "${shas[$i]}" "${isos[$i]}" "$age"
            return 0
        fi
    done
    return 1
}

# Fetch up to <max_count> recent commits touching <path> in <repo>.
# Emits one "<sha> <iso_date>" line per commit, newest-first.
# Sets _error_reason and returns 2 on failure.
fetch_commits_for_path() {
    local repo="$1" path="$2" max_count="${3:-30}"
    local enc_path; enc_path="$(urlencode "$path")"
    local url="${BC_GITHUB_API}/repos/${repo}/commits?path=${enc_path}&per_page=${max_count}"

    local headers=(-H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28")
    if [[ -n "${BC_TOKEN:-}" ]]; then
        headers+=(-H "Authorization: Bearer ${BC_TOKEN}")
    fi

    debug "GET $url"

    local response http_code body
    if ! response=$(curl -sS --max-time 15 -w $'\n%{http_code}' "${headers[@]}" "$url" 2>&1); then
        _error_reason="curl error fetching commits list: $(mask_token "$response")"
        return 2
    fi
    http_code="${response##*$'\n'}"
    body="${response%$'\n'*}"
    if [[ "$body" == "$response" ]]; then body=""; fi

    case "$http_code" in
        200) ;;
        403)
            if printf '%s' "$body" | jq -e '(.message // "") | test("rate limit"; "i")' >/dev/null 2>&1; then
                _error_reason="GitHub API rate limit exceeded for commits list (HTTP 403). Set BREW_COOLDOWN_GITHUB_TOKEN to raise to 5000/hr."
            else
                _error_reason="GitHub HTTP 403 (forbidden) for commits list at $path"
            fi
            return 2 ;;
        404) _error_reason="formula not found at $repo/$path (HTTP 404)"; return 2 ;;
        000) _error_reason="curl failed before HTTP exchange (network error)"; return 2 ;;
        *)   _error_reason="GitHub returned HTTP $http_code for commits list at $path"; return 2 ;;
    esac

    local pairs
    if ! pairs=$(printf '%s' "$body" | jq -r '.[] | "\(.sha) \(.commit.committer.date // "")"' 2>/dev/null); then
        _error_reason="malformed JSON from commits API"
        return 2
    fi
    if [[ -z "$pairs" ]]; then
        _error_reason="no commits returned for $path"
        return 2
    fi
    printf '%s\n' "$pairs"
    return 0
}

# Fetch the formula .rb content from raw.githubusercontent.com at a specific
# commit SHA. Returns content on stdout. Sets _error_reason on failure.
fetch_formula_content() {
    local repo="$1" path="$2" sha="$3"
    # SHA is a hex string and path uses safe chars; no urlencoding needed.
    local url="${BC_RAW_GITHUB}/${repo}/${sha}/${path}"

    debug "GET $url"

    local response http_code body
    if ! response=$(curl -sS --max-time 15 -w $'\n%{http_code}' "$url" 2>&1); then
        _error_reason="curl error fetching formula content: $(mask_token "$response")"
        return 2
    fi
    http_code="${response##*$'\n'}"
    body="${response%$'\n'*}"
    if [[ "$body" == "$response" ]]; then body=""; fi

    case "$http_code" in
        200) ;;
        404) _error_reason="formula content not found at $repo/$path@$sha (HTTP 404)"; return 2 ;;
        *)   _error_reason="GitHub returned HTTP $http_code fetching formula content"; return 2 ;;
    esac

    if [[ -z "$body" ]]; then
        _error_reason="empty formula content at $sha"
        return 2
    fi
    printf '%s' "$body"
    return 0
}

# Lazily create a per-invocation tap under $(brew --repository)/Library/Taps/
# at 0700 perms. Installs an EXIT trap that removes the tap dir.
# Sets _rewind_tap_dir and _rewind_tap_ns.
ensure_rewind_tap() {
    [[ -n "$_rewind_tap_dir" && -d "$_rewind_tap_dir" ]] && return 0

    local repo
    if ! repo=$(command brew --repository 2>/dev/null); then
        _error_reason="cannot determine brew --repository for staging tap"
        return 2
    fi
    if [[ -z "$repo" ]]; then
        _error_reason="empty brew --repository result"
        return 2
    fi

    local parent="${repo}/Library/Taps/brew-cooldown"
    if ! mkdir -p "$parent"; then
        _error_reason="cannot create $parent"
        return 2
    fi

    if ! _rewind_tap_dir=$(mktemp -d "${parent}/homebrew-cooldown-XXXXXX"); then
        _error_reason="mktemp -d failed for staging tap"
        return 2
    fi
    chmod 700 "$_rewind_tap_dir" 2>/dev/null || true
    mkdir -p "${_rewind_tap_dir}/Formula"

    local base; base=$(basename "$_rewind_tap_dir")  # homebrew-cooldown-XYZ
    _rewind_tap_ns="brew-cooldown/${base#homebrew-}" # brew-cooldown/cooldown-XYZ

    trap 'cleanup_rewind_tap' EXIT
    debug "staged tap at $_rewind_tap_dir (ns $_rewind_tap_ns)"
    return 0
}

cleanup_rewind_tap() {
    if [[ -n "${_rewind_tap_dir:-}" && -d "$_rewind_tap_dir" ]]; then
        rm -rf "$_rewind_tap_dir"
    fi
    _rewind_tap_dir=""
}

# Write the historical .rb content into the staged tap.
stage_formula() {
    local name="$1" content="$2"
    ensure_rewind_tap || return 2

    local path="${_rewind_tap_dir}/Formula/${name}.rb"
    if ! printf '%s' "$content" > "$path"; then
        _error_reason="cannot write staged formula at $path"
        return 2
    fi
    chmod 600 "$path" 2>/dev/null || true
    return 0
}

# Combine fetch_commits + find_n_stable. Returns 0 + sets _rewound_sha/iso/age
# on success, 1 on no N-stable found, 2 on lookup error (sets _error_reason).
try_rewind() {
    local name="$1" kind="${2:-formula}"
    _rewound_sha=""; _rewound_iso=""; _rewound_age_days=""

    # Casks deferred (ADR-0008); fall through to held.
    [[ "$kind" == "cask" ]] && return 1
    [[ "$kind" != "formula" ]] && return 1

    local path
    if ! path=$(repo_path_for "$name" "$kind"); then
        _error_reason="cannot determine repo path for $name"
        return 2
    fi

    local pairs rc=0
    pairs=$(fetch_commits_for_path "$BC_CORE_REPO" "$path" "$BC_MAX_REWIND_COMMITS") || rc=$?
    if [[ $rc -ne 0 ]]; then return 2; fi

    local result
    if ! result=$(printf '%s\n' "$pairs" | find_n_stable_commit "$BC_DAYS"); then
        return 1
    fi

    # find_n_stable_commit emits "<sha> <iso> <age_days>" — but the script-wide
    # IFS=$'\n\t' would otherwise concatenate the three fields into _rewound_sha.
    IFS=' ' read -r _rewound_sha _rewound_iso _rewound_age_days <<< "$result"
    [[ -n "$_rewound_sha" ]]
}

###############################################################################
# brew invocation (or dry-run print)
###############################################################################

# Run brew with given args. In dry-run mode, prints the would-run argv to stdout
# and returns 0. Otherwise execs brew (replacing this shell). We resolve brew's
# path explicitly via `type -P` to bypass any user alias or function — `exec`
# itself can't run builtins like `command`, so we resolve to a real path.
run_brew() {
    if [[ "${BC_DRY_RUN:-0}" == "1" ]]; then
        local out="brew"
        local arg
        for arg in "$@"; do
            out="$out $(printf '%q' "$arg")"
        done
        printf '%s\n' "$out"
        return 0
    fi
    local brew_bin
    if ! brew_bin=$(type -P brew); then
        die 2 "brew not found in PATH; install Homebrew first (https://brew.sh)"
    fi
    exec "$brew_bin" "$@"
}

# Like run_brew but spawns (doesn't exec). Used for rewound installs where we
# need to keep running afterward (to clean up the staged tap, or to invoke
# brew again for the next rewound formula).
run_brew_spawn() {
    if [[ "${BC_DRY_RUN:-0}" == "1" ]]; then
        local out="brew"
        local arg
        for arg in "$@"; do
            out="$out $(printf '%q' "$arg")"
        done
        printf '%s\n' "$out"
        return 0
    fi
    local brew_bin
    if ! brew_bin=$(type -P brew); then
        die 2 "brew not found in PATH; install Homebrew first (https://brew.sh)"
    fi
    "$brew_bin" "$@"
}

###############################################################################
# command implementations
###############################################################################

# Used by install/upgrade/reinstall when invoked with explicit names.
run_one_command() {
    local subcmd="$1"; shift
    local kind="formula"
    if [[ "${BC_CASK:-0}" == "1" ]]; then kind="cask"; fi

    if [[ $# -eq 0 ]]; then
        die 1 "$subcmd requires at least one name"
    fi

    local n
    for n in "$@"; do
        if ! validate_formula_name "$n"; then
            die 1 "invalid name: '$n' — must match $BC_NAME_RE; third-party taps (user/repo/name) not supported in v1"
        fi
    done

    if [[ "${BC_DISABLE:-0}" == "1" ]]; then
        log_warn "cooldown disabled (--no-cooldown / BREW_COOLDOWN_DISABLE=1); not checking: $*"
        local pre_args=()
        if [[ "$kind" == "cask" ]]; then pre_args+=(--cask); fi
        run_brew "$subcmd" ${pre_args[@]+"${pre_args[@]}"} "$@"
        return
    fi

    local survivors=() held=() errored=()
    # Parallel arrays: rewound[] names, rewound_sha[], rewound_age[]. Same index.
    local rewound=() rewound_sha=() rewound_age=()

    for n in "$@"; do
        local rc=0
        check_cooldown "$n" "$kind" || rc=$?
        case "$rc" in
            0)
                log_info "$n: eligible (latest commit $_latest_commit_iso, age ${_age_days}d, cooldown ${BC_DAYS}d)"
                survivors+=("$n")
                ;;
            1)
                # Try rewind unless opted out or this is a cask (cask rewind deferred to v3).
                if [[ "${BC_NO_REWIND:-0}" != "1" && "$kind" == "formula" ]]; then
                    local rwd_rc=0
                    try_rewind "$n" "$kind" || rwd_rc=$?
                    if [[ $rwd_rc -eq 0 ]]; then
                        log_info "$n: HELD at HEAD; rewinding to $_rewound_sha (${_rewound_age_days}d ago, ${_rewound_iso})"
                        rewound+=("$n")
                        rewound_sha+=("$_rewound_sha")
                        rewound_age+=("$_rewound_age_days")
                        continue
                    fi
                    if [[ $rwd_rc -eq 2 ]]; then
                        if [[ "${BC_FAIL_OPEN:-0}" == "1" ]]; then
                            log_warn "$n: rewind lookup failed ($_error_reason); BREW_COOLDOWN_FAIL_OPEN=1, letting current HEAD through"
                            survivors+=("$n")
                            continue
                        fi
                        log_error "$n: rewind lookup failed (fail-closed): $_error_reason"
                        errored+=("$n")
                        continue
                    fi
                    log_warn "$n: HELD — latest formula commit $_latest_commit_iso (${_age_days}d ago); eligible after $_eligible_at_iso; no N-stable version found within last ${BC_MAX_REWIND_COMMITS} commits"
                else
                    log_warn "$n: HELD — latest formula commit $_latest_commit_iso (${_age_days}d ago); eligible after $_eligible_at_iso"
                fi
                held+=("$n")
                ;;
            2)
                if [[ "${BC_FAIL_OPEN:-0}" == "1" ]]; then
                    log_warn "$n: lookup failed ($_error_reason); BREW_COOLDOWN_FAIL_OPEN=1, letting through"
                    survivors+=("$n")
                else
                    log_error "$n: lookup failed (fail-closed): $_error_reason"
                    errored+=("$n")
                fi
                ;;
        esac
    done

    if [[ ${#errored[@]} -gt 0 ]]; then
        die 2 "fail-closed: refusing to proceed for: ${errored[*]} (override with BREW_COOLDOWN_FAIL_OPEN=1 or --no-cooldown)"
    fi

    if [[ ${#held[@]} -gt 0 && ${#survivors[@]} -eq 0 && ${#rewound[@]} -eq 0 ]]; then
        die 1 "all packages held; bypass with --no-cooldown if intentional"
    fi

    if [[ ${#held[@]} -gt 0 ]]; then
        local proceed_msg=""
        [[ ${#survivors[@]} -gt 0 ]] && proceed_msg="proceeding with current: ${survivors[*]}"
        if [[ ${#rewound[@]} -gt 0 ]]; then
            [[ -n "$proceed_msg" ]] && proceed_msg="$proceed_msg; "
            proceed_msg="${proceed_msg}rewinding: ${rewound[*]}"
        fi
        log_warn "held: ${held[*]}${proceed_msg:+ — $proceed_msg}"
    fi

    # Install rewound formulae one at a time (spawn, not exec), so the staged
    # tap can be cleaned up before we exec for the current-HEAD survivors.
    if [[ ${#rewound[@]} -gt 0 ]]; then
        local i
        for i in "${!rewound[@]}"; do
            local rn="${rewound[$i]}" rsha="${rewound_sha[$i]}"
            local rpath; rpath=$(repo_path_for "$rn" "$kind")
            local rcontent
            if ! rcontent=$(fetch_formula_content "$BC_CORE_REPO" "$rpath" "$rsha"); then
                cleanup_rewind_tap
                die 2 "could not fetch rewound formula content for $rn at $rsha: $_error_reason"
            fi
            if ! stage_formula "$rn" "$rcontent"; then
                cleanup_rewind_tap
                die 2 "could not stage rewound formula $rn: $_error_reason"
            fi
        done

        for i in "${!rewound[@]}"; do
            local rn="${rewound[$i]}"
            log_info "$rn: installing rewound version via ${_rewind_tap_ns}/${rn} (--force-bottle)"
            local rc=0
            run_brew_spawn "$subcmd" --force-bottle "${_rewind_tap_ns}/${rn}" || rc=$?
            if [[ $rc -ne 0 ]]; then
                cleanup_rewind_tap
                die "$rc" "brew install failed for rewound $rn (rc=$rc) — bottle may be unavailable; raise --days, use --no-rewind, or use --no-cooldown if you've verified"
            fi
        done

        # Clean up the staged tap explicitly before exec on normal survivors,
        # since exec replaces this process and the EXIT trap would not fire.
        cleanup_rewind_tap
    fi

    if [[ ${#survivors[@]} -eq 0 ]]; then
        return 0
    fi

    local pre_args=()
    if [[ "$kind" == "cask" ]]; then pre_args+=(--cask); fi
    run_brew "$subcmd" ${pre_args[@]+"${pre_args[@]}"} "${survivors[@]}"
}

cmd_install()   { run_one_command install   "$@"; }
cmd_reinstall() { run_one_command reinstall "$@"; }

cmd_upgrade() {
    if [[ $# -gt 0 ]]; then
        run_one_command upgrade "$@"
        return
    fi
    if [[ "${BC_CASK:-0}" == "1" ]]; then
        die 1 "'upgrade --cask' without explicit cask names is not supported in v1; specify casks explicitly or use 'brew upgrade --cask' directly"
    fi

    local outdated_json
    if ! outdated_json=$(command brew outdated --json=v2 --formula 2>&1); then
        die 2 "could not run 'brew outdated': $(mask_token "$outdated_json")"
    fi

    local names
    if ! names=$(printf '%s' "$outdated_json" | jq -r '.formulae[].name' 2>/dev/null); then
        die 2 "could not parse 'brew outdated' JSON"
    fi
    if [[ -z "$names" ]]; then
        log_info "nothing to upgrade"
        return 0
    fi

    local arr=() n
    while IFS= read -r n; do
        if [[ -n "$n" ]]; then arr+=("$n"); fi
    done <<< "$names"

    if [[ ${#arr[@]} -eq 0 ]]; then
        log_info "nothing to upgrade"
        return 0
    fi

    run_one_command upgrade "${arr[@]}"
}

###############################################################################
# usage
###############################################################################

usage() {
    cat <<EOF
brew-cooldown $BC_VERSION — refuse Homebrew install/upgrade/reinstall of any
formula whose current version landed less than N days ago (default $BC_DEFAULT_DAYS).

USAGE
  brew-cooldown [GLOBAL FLAGS] <subcommand> [args...]

SUBCOMMANDS (only these — anything else is rejected)
  install <name>...        install with cooldown check
  upgrade [<name>...]      upgrade named (or all outdated formulae)
  reinstall <name>...      reinstall with cooldown check

GLOBAL FLAGS
  --days N                 cooldown days (overrides env / config)
  --no-cooldown            disable the check (logs a warning to stderr)
  --no-rewind              don't rewind to an N-stable predecessor when held; refuse instead (ADR-0008)
  --cask                   target a cask instead of a formula
  --dry-run                print the would-run brew command and exit; do not run brew
  --debug                  verbose debug output to stderr
  -h, --help               show this help
  -v, --version            print version

CONFIG (precedence: flag > env > config file > default)
  Env: BREW_COOLDOWN_DAYS, BREW_COOLDOWN_GITHUB_TOKEN, BREW_COOLDOWN_FAIL_OPEN,
       BREW_COOLDOWN_DISABLE, BREW_COOLDOWN_DEBUG, BREW_COOLDOWN_NO_REWIND,
       BREW_COOLDOWN_MAX_REWIND_COMMITS (default $BC_DEFAULT_MAX_REWIND_COMMITS, range 1-100)
  File: \${XDG_CONFIG_HOME:-\$HOME/.config}/brew-cooldown/config

See docs/spec.md for behavior, docs/threat-model.md for what's protected.
EOF
}

###############################################################################
# main
###############################################################################

main() {
    BC_DAYS=""
    BC_TOKEN=""
    BC_FAIL_OPEN=""
    BC_DISABLE=""
    BC_DEBUG=""
    BC_NO_REWIND=""
    BC_MAX_REWIND_COMMITS=""
    BC_DRY_RUN=0
    BC_CASK=0

    load_config
    [[ -n "$_cfg_days" ]]                && BC_DAYS="$_cfg_days"
    [[ -n "$_cfg_token" ]]               && BC_TOKEN="$_cfg_token"
    [[ -n "$_cfg_fail_open" ]]           && BC_FAIL_OPEN="$_cfg_fail_open"
    [[ -n "$_cfg_disable" ]]             && BC_DISABLE="$_cfg_disable"
    [[ -n "$_cfg_debug" ]]               && BC_DEBUG="$_cfg_debug"
    [[ -n "$_cfg_no_rewind" ]]           && BC_NO_REWIND="$_cfg_no_rewind"
    [[ -n "$_cfg_max_rewind_commits" ]]  && BC_MAX_REWIND_COMMITS="$_cfg_max_rewind_commits"

    [[ -n "${BREW_COOLDOWN_DAYS:-}" ]]      && BC_DAYS="$BREW_COOLDOWN_DAYS"
    [[ -n "${BREW_COOLDOWN_GITHUB_TOKEN:-}" ]] && BC_TOKEN="$BREW_COOLDOWN_GITHUB_TOKEN"
    if [[ -z "$BC_TOKEN" && -n "${HOMEBREW_GITHUB_API_TOKEN:-}" ]]; then
        BC_TOKEN="$HOMEBREW_GITHUB_API_TOKEN"
    fi
    [[ -n "${BREW_COOLDOWN_FAIL_OPEN:-}" ]] && BC_FAIL_OPEN="$BREW_COOLDOWN_FAIL_OPEN"
    [[ -n "${BREW_COOLDOWN_DISABLE:-}" ]]   && BC_DISABLE="$BREW_COOLDOWN_DISABLE"
    [[ -n "${BREW_COOLDOWN_DEBUG:-}" ]]     && BC_DEBUG="$BREW_COOLDOWN_DEBUG"
    [[ -n "${BREW_COOLDOWN_NO_REWIND:-}" ]] && BC_NO_REWIND="$BREW_COOLDOWN_NO_REWIND"
    if [[ -n "${BREW_COOLDOWN_MAX_REWIND_COMMITS:-}" ]]; then
        if [[ "$BREW_COOLDOWN_MAX_REWIND_COMMITS" =~ ^[0-9]{1,3}$ ]] && (( BREW_COOLDOWN_MAX_REWIND_COMMITS >= 1 && BREW_COOLDOWN_MAX_REWIND_COMMITS <= 100 )); then
            BC_MAX_REWIND_COMMITS="$BREW_COOLDOWN_MAX_REWIND_COMMITS"
        else
            die 1 "BREW_COOLDOWN_MAX_REWIND_COMMITS must be 1-100 (got: $BREW_COOLDOWN_MAX_REWIND_COMMITS)"
        fi
    fi

    local positional=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --days)
                if [[ $# -lt 2 ]]; then die 1 "--days requires an argument"; fi
                if [[ ! "$2" =~ ^[0-9]{1,4}$ ]]; then die 1 "--days must be 1-4 digits (got: $2)"; fi
                BC_DAYS="$2"; shift 2 ;;
            --no-cooldown) BC_DISABLE=1; shift ;;
            --no-rewind)   BC_NO_REWIND=1; shift ;;
            --cask)        BC_CASK=1;    shift ;;
            --dry-run)     BC_DRY_RUN=1; shift ;;
            --debug)       BC_DEBUG=1;   shift ;;
            -h|--help)     usage; exit 0 ;;
            -v|--version)  printf 'brew-cooldown %s\n' "$BC_VERSION"; exit 0 ;;
            --)
                shift
                while [[ $# -gt 0 ]]; do positional+=("$1"); shift; done
                ;;
            -*)            die 1 "unknown flag: $1 (try --help)" ;;
            *)             positional+=("$1"); shift ;;
        esac
    done

    [[ -z "$BC_DAYS" ]]                && BC_DAYS="$BC_DEFAULT_DAYS"
    [[ -z "$BC_FAIL_OPEN" ]]           && BC_FAIL_OPEN=0
    [[ -z "$BC_DISABLE" ]]             && BC_DISABLE=0
    [[ -z "$BC_DEBUG" ]]               && BC_DEBUG=0
    [[ -z "$BC_NO_REWIND" ]]           && BC_NO_REWIND=0
    [[ -z "$BC_MAX_REWIND_COMMITS" ]]  && BC_MAX_REWIND_COMMITS="$BC_DEFAULT_MAX_REWIND_COMMITS"

    if [[ ${#positional[@]} -eq 0 ]]; then
        usage; exit 1
    fi

    local subcmd="${positional[0]}"
    local rest=()
    if [[ ${#positional[@]} -gt 1 ]]; then
        rest=("${positional[@]:1}")
    fi

    case "$subcmd" in
        install)   cmd_install   ${rest[@]+"${rest[@]}"} ;;
        upgrade)   cmd_upgrade   ${rest[@]+"${rest[@]}"} ;;
        reinstall) cmd_reinstall ${rest[@]+"${rest[@]}"} ;;
        *) die 1 "unsupported subcommand: '$subcmd'. Supported: install, upgrade, reinstall. Use 'brew $subcmd ...' directly for anything else." ;;
    esac
}

# Lib mode: when sourced from tests with BREW_COOLDOWN_LIB_ONLY=1, define
# functions only. Otherwise run main.
if [[ "${BREW_COOLDOWN_LIB_ONLY:-0}" != "1" ]]; then
    main "$@"
fi
